<% layout("/layouts/boilerplates")%>
<body>
    <div class="row justify-content-center">
        <div class="col-8">
    <br>
    <h3>Create a New Listing</h3>
    
    <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

       <div class="mb-3">
         <lable for="title" class="form-label">Title</lable>
        <input name="listing[title]" placeholder="Adda catchy title" type="text" class="form-control" required/>
        <div class="valid-feedback">Looks good!</div>
       </div>
        
        <div>
            <lable for="description" class="form-label">Description</lable>
            <textarea name="listing[description]"  type="text" class="form-control" required></textarea>
            <div class="invalid-feedback">Please Enter a Short Description!</div>
        </div>
        
        <div>
            <lable for="image" class="form-label">Upload Listing Image</lable>
            <input name="listing[image]" type="file" class="form-control">
            required
        </div>
        
        <div class="row">
        <div class="mb-3 col-md-4">
            <lable for="price" class="form-label">Price</lable>
            <input name="listing[price]" placeholder="1000"  class="form-control" required>
            <div class="invalid-feedback">Price should be valid!</div>
        </div>    
        
        <div class="mb-3 col-md-8">
            <lable for="country" class="form-label">Country</lable>
            <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
            <div class="invalid-feedback">Country name should be valid!</div>
        </div>
        </div>
        
        <div>
            <lable for="location" class="form-label">Location</lable>
            <input name="listing[location]" placeholder="Hajipur, Bihar" type="text" class="form-control" required>
            <div class="invalid-feedback">Location should be valid!</div>
        </div>
        <br><br>
        <button class="btn btn-dark add-btn">Add</button>
    </form>
    </div>
    </div>    

</body>
</html>